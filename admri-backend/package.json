{
  "name": "admri-backend",
  "version": "1.0.0",
  "description": "ADMRI Backend — Node.js + Express + PostgreSQL",
  "main": "src/server.js",
  "scripts": {
    "start":   "node src/server.js",
    "dev":     "nodemon src/server.js",
