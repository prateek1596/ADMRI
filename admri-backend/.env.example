# Server
PORT=5000
NODE_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=admri_db
DB_USER=admri_user
DB_PASSWORD=Prateek@1596

# JWT
JWT_SECRET=1234567890abcdef1234567890abcdef
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=1234567890abcdef1234567890abcdef
JWT_REFRESH_EXPIRES_IN=7d

# Email alerts (Nodemailer — use Gmail App Password or SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
ALERT_FROM=ADMRI System <your_email@gmail.com>

# Risk spike alert threshold (points)
RISK_SPIKE_THRESHOLD=15

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Frontend origin (CORS)
CLIENT_ORIGIN=http://localhost:3000
